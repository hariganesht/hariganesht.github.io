<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --text:#1a1a18;--text-muted:#5a5a55;--text-faint:#8a8a84;
  --bg:#faf9f6;--bg-card:#f3f1ec;--border:#dedad3;
  --accent:#3b5a8a;--accent-light:#e8edf5;--accent-border:#c5d2e8;
  --font-serif:'EB Garamond',Georgia,serif;
  --font-mono:'DM Mono','Courier New',monospace;
}
html{font-size:17px}
body{font-family:var(--font-serif);background:var(--bg);color:var(--text);line-height:1.75;min-height:100vh}
nav{position:sticky;top:0;z-index:100;background:var(--bg);border-bottom:1px solid var(--border);padding:0 2rem}
.nav-inner{max-width:820px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:52px}
.nav-name{font-family:var(--font-serif);font-size:1rem;font-weight:500;color:var(--text);text-decoration:none}
.nav-links{display:flex;gap:1.8rem;list-style:none}
.nav-links a{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.06em;color:var(--text-muted);text-decoration:none;transition:color .15s}
.nav-links a:hover,.nav-links a.active{color:var(--accent)}
main{max-width:820px;margin:0 auto;padding:4rem 2rem 6rem}
a{color:var(--accent);text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px}
a:hover{text-decoration-thickness:2px}

.page-title{font-size:1.8rem;font-weight:400;margin-bottom:.4rem}
.page-sub{font-family:var(--font-mono);font-size:.7rem;letter-spacing:.06em;color:var(--text-muted);margin-bottom:2.5rem}
section{margin-bottom:3rem}
.sec-label{font-family:var(--font-mono);font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;color:var(--text-faint);margin-bottom:1.1rem;padding-bottom:.5rem;border-bottom:1px solid var(--border)}

/* PAPER CARD */
.paper{padding:1.2rem 0;border-bottom:1px solid var(--border)}
.paper:first-child{padding-top:0}
.paper:last-child{border-bottom:none}
.paper-inner{display:grid;grid-template-columns:1fr auto;gap:1.5rem;align-items:start}
.ptitle{font-size:1.02rem;font-weight:500;margin-bottom:.2rem}
.ptitle a{color:var(--text);text-decoration:none}
.ptitle a:hover{color:var(--accent)}
.pauthors{font-size:.88rem;color:var(--text-muted);margin-bottom:.15rem}
.pvenue{font-family:var(--font-mono);font-size:.67rem;color:var(--text-faint);margin-bottom:.35rem}
.pdesc{font-size:.9rem;color:var(--text-muted);margin-bottom:.45rem;line-height:1.6}
.plinks{display:flex;flex-wrap:wrap;gap:.5rem}
.plinks a{font-family:var(--font-mono);font-size:.65rem;color:var(--accent);background:var(--accent-light);border:1px solid var(--accent-border);padding:2px 8px;border-radius:2px;text-decoration:none}
.plinks a:hover{background:#dbe4f0}
.badge{font-family:var(--font-mono);font-size:.63rem;letter-spacing:.04em;padding:3px 9px;border-radius:2px;white-space:nowrap;align-self:start;margin-top:3px}
.badge-pub{color:#2d6645;background:#e6f2ec;border:1px solid #b8dcc8}
.badge-wip{color:#7a5c1e;background:#fdf3df;border:1px solid #f0d9a0}
.badge-pre{color:#4a4098;background:#eeedf8;border:1px solid #c8c4ee}

/* MISC / TALKS */
.entry{padding:.75rem 0;border-bottom:1px solid var(--border);display:grid;grid-template-columns:90px 1fr;gap:1rem;font-size:.93rem}
.entry:first-child{padding-top:0}
.entry:last-child{border-bottom:none}
.edate{font-family:var(--font-mono);font-size:.67rem;color:var(--text-faint);padding-top:3px}
.etitle{font-weight:500;margin-bottom:.1rem}
.emeta{font-size:.85rem;color:var(--text-muted)}

footer{border-top:1px solid var(--border);text-align:center;padding:2rem;font-family:var(--font-mono);font-size:.65rem;letter-spacing:.06em;color:var(--text-faint)}
@media(max-width:600px){.paper-inner{grid-template-columns:1fr}.badge{display:inline-block}.entry{grid-template-columns:1fr;gap:.15rem}}
</style>
</head>
